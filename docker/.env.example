# hermes-dispatch Docker environment.
# Copy to .env and edit:  cp .env.example .env
# .env is gitignored. Never commit real keys.

# ─── Required ────────────────────────────────────────────────────────────────
# The master key the dispatch server uses to authenticate to LiteLLM. Any
# non-empty string; change it from the default.
LITELLM_MASTER_KEY=sk-local-change-me

# ─── Backend posture, pick ONE ───────────────────────────────────────────────
# (a) CLOUD (default below): set the provider keys you actually use. Unused ones
#     can stay blank. LiteLLM reads these automatically.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# (b) LOCAL OLLAMA on the host: set OLLAMA_BASE and switch the MODEL_* values
#     below to ollama_chat/<tag>. The container reaches the host via
#     host.docker.internal. Leave blank for cloud.
OLLAMA_BASE=
# OLLAMA_BASE=http://host.docker.internal:11434

# ─── Alias → model map ───────────────────────────────────────────────────────
# One per alias. Defaults target cloud (see examples/models-cloud.yaml). For
# local Ollama, set OLLAMA_BASE above and use ollama_chat/<tag> values here
# (see examples/models-m4-apple-silicon.yaml or models-nvidia-24gb.yaml).
MODEL_CLASSIFY=openai/gpt-4o-mini
MODEL_CHAT=openai/gpt-4o-mini
MODEL_REVIEW=anthropic/claude-3-5-haiku-latest
MODEL_CODE=anthropic/claude-3-5-sonnet-latest
MODEL_ANALYZE=openai/o4-mini
MODEL_PIPELINE=openai/gpt-4o-mini
MODEL_WRITE=openai/gpt-4o
MODEL_QUALITY=anthropic/claude-3-5-sonnet-latest

# ─── Optional ────────────────────────────────────────────────────────────────
# Obsidian save-to-vault (leave blank to disable). Must be a path reachable
# INSIDE the dispatch container. Mount your vault as a volume if you enable it.
OBSIDIAN_VAULT=
